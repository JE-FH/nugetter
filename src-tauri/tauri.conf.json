{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nugetter",
  "version": "999.0.2",
  "identifier": "com.nugetter.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run tauri:before-build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "nugetter",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "rpm",
      "msi",
      "dmg",
      "app",
      "nsis"
    ],
    "icon": []
  }
}
