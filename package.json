{
  "name": "nugetter",
  "private": true,
  "version": "999.0.0-localbuild",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:icons": "tauri icon src-tauri/icons/logo.svg -o src-tauri/icons",
    "apply:tag-version": "node .github/workflows/apply-tag-version.mjs",
    "check": "biome check .",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "build": "npm run generate:icons && tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@tauri-apps/cli": "^2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
